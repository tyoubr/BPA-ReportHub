<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Report Hub</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/QCO.styles.css" asp-append-version="true" />



    <link rel="stylesheet" href="~/css/thirdparty.bundle.css" />
    <script src="~/js/thirdparty.bundle.js"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.13/css/select2.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0-beta2/dist/css/bootstrap.min.css" rel="stylesheet">
   

</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                               <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                            </li>

                            <!-- Dropdown for Reports -->
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-dark" href="#" id="reportsDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Reports
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="reportsDropdown">
                                    <li><a class="dropdown-item" asp-controller="ReportCalling" asp-action="Viewer" asp-route-reportName="GreyStockReport">Grey Stock Report</a></li>
                                    <li><a class="dropdown-item" asp-controller="ReportCalling" asp-action="Viewer" asp-route-reportName="rptShipment">Daily Shipment Status</a></li>
                                    <li><a class="dropdown-item" asp-controller="ReportCalling" asp-action="Viewer1" asp-route-reportName="rptYarnAging">LOT Wise Yarn Aging Report</a></li>
                                    <li><a class="dropdown-item" asp-controller="ReportCalling" asp-action="Viewer2" asp-route-reportName="rptWorkOrderFOllowup_Tex">Outside Textile Work Order Follow Up</a></li>
                                    <li><a class="dropdown-item" asp-controller="ReportCalling" asp-action="Viewer3" asp-route-reportName="rptSewingWIP">Sewing Input Output Report</a></li>
                                    <li><a class="dropdown-item" asp-controller="ReportCalling" asp-action="DyeingProd" asp-route-reportName="rptDyeingProduction">Dyeing Production Report</a></li>
                                    <li><a class="dropdown-item" asp-controller="ReportCalling" asp-action="DyeingProd1" asp-route-reportName="rptDyeing_Production_WC">Dyeing Production Report(WC)</a></li>
                                    <li><a class="dropdown-item" asp-controller="ReportCalling" asp-action="DyeingKPI" asp-route-reportName="rptDyeingKPI">Dyeing KPI Report</a></li>
                                    <li><a class="dropdown-item" asp-controller="ReportCalling" asp-action="PieceRate" asp-route-reportName="rptDailySewingProduction">Daily Sewing Input Output Report (Piece Rate)</a></li>
                                    <li><a class="dropdown-item" asp-controller="ReportCalling" asp-action="LineWiseWIP" asp-route-reportName="rptLineWiseWIP">Line Wise Sewing Input Output</a></li>
                                    <li><a class="dropdown-item" asp-controller="ReportCalling" asp-action="Test" asp-route-reportName="rptGreyTransferFollowUp">Grey Transfer Report</a></li>
                                    <li><a class="dropdown-item" asp-controller="ReportCalling" asp-action="DHU" asp-route-reportName="rptFinalDHU">Sewing DHU</a></li>
                                    <li><a class="dropdown-item" asp-controller="ReportCalling" asp-action="GP_OUT" asp-route-reportName="rptGatePass_Out">Gate Pass_OUT</a></li>
                                    <li><a class="dropdown-item" asp-controller="ReportCalling" asp-action="FIN_FAB_STOCK" asp-route-reportName="rptFinishFabStock">Finish Fabric RCV & ISSUE</a></li>
                                    <li><a class="dropdown-item" asp-controller="ReportCalling" asp-action="DyeingCost" asp-route-reportName="rptDyeingCost">Dyeing Cost Details</a></li>
                                    <li><a class="dropdown-item" asp-controller="ReportCalling" asp-action="YarnAllocation" asp-route-reportName="rptYarnAllocation">Yarn Allocation Report</a></li>
                                </ul>
                            </li>
                        }
                    @* </ul> *@
                    @* <partial name="_LoginPartial" /> *@
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <div class="text-center my-4 p-4 bg-light rounded shadow-sm border">

            @{
                var userName = User.Identity?.Name ?? "Guest";
                var greeting = DateTime.Now.Hour < 12 ? "Good Morning"
                : DateTime.Now.Hour < 17 ? "Good Afternoon"
                : "Good Evening";
            }

            <!-- Greeting -->
            <h2 class="fw-normal text-secondary mb-2">
                @greeting,
                <span class="text-primary fw-bold">Mr. @userName</span>
            </h2>

            <!-- Role Based Welcome -->
            <h1 class="fw-bold text-dark">
                <text>Welcome to <span class="text-success">Report Hub</span></text>

             @*    @if (User.IsInRole("Admin") || User.IsInRole("User"))
                {
                    <text>Welcome to <span class="text-success">Report Hub</span></text>
                }
                else if (User.IsInRole("SpecialAccess"))
                {
                    <text>Welcome to <span class="text-info">Report Hub</span></text>
                }
                else
                {
                    <text>Welcome <span class="text-muted">Guest</span></text>
                } *@

            </h1>

            <!-- Sub Text -->
            <p class="lead mt-3 text-muted">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <text>You are logged in as <strong>Mr. @userName</strong></text>
                }
                else
                {
                    <text>Please log in to access your dashboard.</text>
                }
            </p>

        </div>
        @RenderBody()
    </div>

    @* <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2024 - QCO - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer> *@

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- Select2 JS -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.13/js/select2.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0-beta2/dist/js/bootstrap.bundle.min.js"></script>
  
  
    @await RenderSectionAsync("Scripts", required: false) <!-- Optional section for additional scripts -->
</body>

</html>
